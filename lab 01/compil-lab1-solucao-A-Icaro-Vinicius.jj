PARSER_BEGIN(CompilLab1SolucaoAIcaroVinicius)

public class CompilLab1SolucaoAIcaroVinicius {

    public static void main(String args[]) throws Exception {
        CompilLab1SolucaoAIcaroVinicius scanner = new CompilLab1SolucaoAIcaroVinicius(System.in);

        java.util.Map constants = new java.util.HashMap();

        Class clazz = CompilLab1SolucaoAIcaroViniciusConstants.class;
        java.lang.reflect.Field[] fields = clazz.getFields();

        for (int i = 0; i < fields.length; i++) {
            java.lang.reflect.Field field = fields[i];

            if (field.getType() == int.class) {
                int modifiers = field.getModifiers();

                boolean isConstant =
                        java.lang.reflect.Modifier.isPublic(modifiers) &&
                        java.lang.reflect.Modifier.isStatic(modifiers) &&
                        java.lang.reflect.Modifier.isFinal(modifiers);

                if (isConstant) {
                    constants.put(
                            Integer.valueOf(field.getInt(null)),
                            field.getName()
                    );
                }
            }
        }

        Token t;

        do {
            t = scanner.getNextToken();

            if (t.kind != CompilLab1SolucaoAIcaroViniciusConstants.EOF) {
                System.out.println(
                        constants.get(Integer.valueOf(t.kind)) + " " + t.image
                );
            }

        } while (t.kind != CompilLab1SolucaoAIcaroViniciusConstants.EOF);
    }
}

PARSER_END(CompilLab1SolucaoAIcaroVinicius)

SKIP: { 
    //whitespace
    " "
    |"\t"
    |"\n"
    |"\r"
    
    //comments
    |<"//" (~["\n","\r"])*>
    |< "/*" (~["*"])* ( "*" (~["/"] (~["*"])* )* )* "/" >
}

