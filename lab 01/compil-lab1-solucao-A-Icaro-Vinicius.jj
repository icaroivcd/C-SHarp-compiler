TOKEN : {
    //identifiers
      <IDENTIFIER: (["a"-"z","A"-"Z","_"])(["a"-"z","A"-"Z","0"-"9","_"])*>
    | <VERBATIM_IDENTIFIER: "@" (["a"-"z","A"-"Z","_"])(["a"-"z","A"-"Z","0"-"9","_"])*>
}

TOKEN : {
    //operators

    //aritmetic operations
      <PLUS_ASSIGN: "+=">
    | <MINUS_ASSIGN: "-=">
    | <MULT_ASSIGN: "*=">
    | <DIV_ASSIGN: "/=">
    | <MOD_ASSIGN: "%=">
    | <INCREMENT: "++">
    | <DECREMENT: "--">
    | <PLUS: "+">
    | <MINUS: "-">
    | <MULT: "*">
    | <DIV: "/">
    | <MOD: "%">

    //comparison operations
    | <EQ: "==">
    | <NE: "!=">
    | <LE: "<=">
    | <GE: ">=">
    | <LT: "<">
    | <GT: ">">

    //logical operations
    | <LOGICAL_AND: "&&">
    | <LOGICAL_OR: "||">
    | <LOGICAL_NOT: "!">

    //bitwise operations
    | <LEFT_SHIFT_ASSIGN: "<<=">
    | <RIGHT_SHIFT_ASSIGN: ">>=">
    | <AND_ASSIGN: "&=">
    | <OR_ASSIGN: "|=">
    | <XOR_ASSIGN: "^=">
    | <LEFT_SHIFT: "<<">
    | <RIGHT_SHIFT: ">>">
    | <BITWISE_AND: "&">
    | <BITWISE_OR: "|">
    | <BITWISE_XOR: "^">
    | <BITWISE_NOT: "~">

    //other operators
    | <NULL_COALESCING_ASSIGN: "??=">
    | <NULL_COALESCING: "??">
    | <NULL_CONDITIONAL: "?.">
    | <NULL_CONDITIONAL_INDEX: "?[">
    | <LAMBDA: "=>">
    | <POINTER: "->">
    | <RANGE: "..">
    | <QUESTION: "?">
    | <COLON: ":">
    | <ASSIGN: "=">
}

TOKEN : {
    //delimiters
      <SCOPE: "::">
    | <DOT: ".">
    | <COMMA: ",">
    | <SEMICOLON: ";">
    | <LPAREN: "(">
    | <RPAREN: ")">
    | <LBRACE: "{">
    | <RBRACE: "}">
    | <LBRACKET: "[">
    | <RBRACKET: "]">
}

TOKEN : {
    //literals
    
    //real literals (DEVE VIR ANTES dos inteiros!)
      <REAL_LITERAL: (<DECIMAL_DIGITS> "." <DECIMAL_DIGITS> (<EXPONENT>)? (<REAL_SUFFIX>)?)
                   | ("." <DECIMAL_DIGITS> (<EXPONENT>)? (<REAL_SUFFIX>)?)
                   | (<DECIMAL_DIGITS> <EXPONENT> (<REAL_SUFFIX>)?)
                   | (<DECIMAL_DIGITS> <REAL_SUFFIX>)>
    | <#DECIMAL_DIGITS: (["0"-"9"]) (["0"-"9","_"])*>
    | <#EXPONENT: ["e","E"] (["+","-"])? (["0"-"9"]) (["0"-"9","_"])*>
    | <#REAL_SUFFIX: ["f","F","d","D","m","M"]>
    
    //integer literals
    | <INTEGER_LITERAL: (<DECIMAL_LITERAL> | <HEX_LITERAL> | <BINARY_LITERAL>) (<INTEGER_SUFFIX>)?>
    | <#DECIMAL_LITERAL: "0" | (["1"-"9"] (["0"-"9","_"])*)>
    | <#HEX_LITERAL: "0" ["x","X"] (["0"-"9","a"-"f","A"-"F"]) (["0"-"9","a"-"f","A"-"F","_"])*>
    | <#BINARY_LITERAL: "0" ["b","B"] (["0","1"]) (["0"-"1","_"])*>
    | <#INTEGER_SUFFIX: ["u","U"] (["l","L"])? (["l","L"])? | (["l","L"]) (["l","L"])? (["u","U"])?>
    
    //character literal
    | <CHARACTER_LITERAL: "'" (<CHAR_CONTENT>) "'">
    | <#CHAR_CONTENT: (~["'","\\","\r","\n"]) | ("\\" ["'","\"","\\","0","a","b","f","n","r","t","v"]) | ("\\x" (["0"-"9","a"-"f","A"-"F"]){1,4}) | ("\\u" (["0"-"9","a"-"f","A"-"F"]){4}) | ("\\U" (["0"-"9","a"-"f","A"-"F"]){8})>
    
    //string literals
    | <INTERPOLATED_VERBATIM_STRING: (("$@") | ("@$")) "\"" ((~["\""])  | ("\"\"") | "{" | "}")* "\"">
    | <INTERPOLATED_STRING: "$\"" ((~["\"","\\"] ) | ("\\" (~[])) | ("{{") | ("}}"))* "\"">
    | <VERBATIM_STRING_LITERAL: "@\"" ((~["\""]) | "\"\"")* "\"">
    | <STRING_LITERAL: "\"" ((~["\"","\\","\r","\n"]) | ("\\" (~[])))* "\"">
}


